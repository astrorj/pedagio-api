# API Maplink (valores reais de pedágio)
# Cole abaixo as chaves que a Maplink te enviar (contato: https://maplink.global/)
MAPLINK_CLIENT_ID=
MAPLINK_CLIENT_SECRET=

# Opcional: Infosimples - consulta tipo de veículo pela placa
# https://infosimples.com/consultas/antt-veiculo/
INFOSIMPLES_TOKEN=
INFOSIMPLES_EMAIL=

# Porta do servidor
PORT=3000
